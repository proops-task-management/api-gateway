PORT=8080
SPRING_CLOUD_GATEWAY_ROUTES_USER_SERVICE_URL=http://user-service:8081
SPRING_CLOUD_GATEWAY_ROUTES_TASK_SERVICE_URL=http://task-service:8082
SPRING_CLOUD_GATEWAY_ROUTES_NOTIFICATION_SERVICE_URL=http://notification-service:8083
# RS256 verify-only (amended 2026-07-07 — IRD-003 / ADR-005). Newest-first list of PEM public
# keys; the gateway holds NO private key. Locally: export JWT_PUBLIC_KEYS="$(cat jwt-public-dev.pem)"
# (the public half of user-service's dev keypair). In k8s: ESO from SSM /proops/<env>/jwt/public_key.
JWT_PUBLIC_KEYS=-----BEGIN PUBLIC KEY-----\nreplace_with_dev_rsa_public_key_pem\n-----END PUBLIC KEY-----
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

